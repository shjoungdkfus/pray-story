# release 서명용 키 설정 템플릿
#
# 사용법:
# 1. 이 파일을 같은 폴더에 "key.properties" 라는 이름으로 복사한다. (key.properties는 .gitignore에 등록되어 있어 git에 커밋되지 않음)
# 2. 아래 값을 실제 업로드 키(keystore) 정보로 채운다.
# 3. storeFile은 절대 경로 또는 이 파일(android 폴더) 기준 상대 경로를 사용할 수 있다.
#
# key.properties가 존재하지 않거나 storeFile이 가리키는 keystore가 없으면
# build.gradle.kts는 release 빌드를 debug 키로 자동 폴백한다 (빌드가 깨지지 않도록).

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=YOUR_KEY_ALIAS
storeFile=/absolute/path/to/upload-keystore.jks
